# Copy to .env (in the repo root or in the sub-project you run; the scripts
# auto-load a local .env) and fill in the keys for the providers you use.
#
# Only the keys for the model(s) you actually evaluate need to be set, with one
# exception: the multi-document QA pipelines use OpenAI for embeddings and the
# LLM judge, so OPENAI_API_KEY is required there regardless of the reader model.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
